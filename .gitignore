# --- PACE runtime artifacts (created by `pace init`; never committed) ---
# This repo is the published source. The maintainer keeps a separate copy
# of this folder as their actual vault.
/memories/
/projects/
/system/pace_index.db
/system/pace_index.db-wal
/system/pace_index.db-shm
/system/.pace.lock
/system/logs/
pace_config.yaml

# Vault-root .mcp.json is generated by `pace init`; it embeds the local
# Python interpreter path and is machine-specific. Anchored to the repo
# root only so plugin/.mcp.json (committed plugin source) isn't ignored.
/.mcp.json

# plugin/server/ — defensive ignore. The build script stages bundled
# source under a system temp dir (not in the source tree) and zips
# from there, so this path shouldn't normally exist. Kept ignored in
# case a stale build artifact lands here.
plugin/server/

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
build/
dist/
.eggs/

# --- Virtualenvs ---
.venv/
venv/
env/

# --- Tooling caches ---
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
htmlcov/

# --- OS & editor ---
.DS_Store
Thumbs.db
desktop.ini
.idea/
.vscode/
*.swp

# --- OneDrive sync residue ---
*.tmp
~$*
* (Conflicted Copy *).md

# --- Claude Cowork local state ---
.claude/settings.local.json

# --- Internal / maintainer-only docs (not shipped to public repo) ---
# Kept on the maintainer's local disk for reference; never pushed.
/PACE PRD.md
/PACE Dev Plan.md
/PACE Plugin Conversion Brief.md
/CLAUDE.md
# Scratch / draft notes the maintainer keeps alongside the source.
/scratch/
/notes/
